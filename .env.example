# --- Core ---

# Server port (inside the container when using Docker; map a host port separately)
PORT=3000

# Directory where idea .md files are stored.
# Local dev: ./ideas   |   Docker: /data (a mounted volume)
IDEAS_DIR=./ideas

# Optional: Anthropic API key enables AI auto-categorization & rubric scoring.
# Without it, ideas still save fine — they just aren't auto-categorized.
# Get one at https://console.anthropic.com/
CLAUDE_API_KEY=

# --- Tailscale sidecar (Docker, optional) ---

# Tailscale auth key. When set, `docker compose --profile tailscale up` joins
# the container to your tailnet and serves HTTPS via Tailscale Serve.
# Create one at https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-...

# Hostname the app will appear as on your tailnet (MagicDNS).
# TS_HOSTNAME=ideaforge
